# Slack App credentials — set in your Slack App dashboard
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_SIGNING_SECRET=your-signing-secret
SLACK_APP_TOKEN=xapp-your-app-token      # for Socket Mode

# Docs-inator API
DOCS_API_URL=http://localhost:8082
DOCS_API_KEY=sk-docai-your-api-key

# Default product/version (can be overridden per channel via /docs set-product)
DEFAULT_PRODUCT=
DEFAULT_VERSION=

# Port for HTTP mode (optional; not needed if using Socket Mode)
PORT=3010
