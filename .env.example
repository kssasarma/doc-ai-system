# ============================================================
# doc-ai-system — Production Environment Variables
# cp .env.example .env  then fill in the values below
# NEVER commit the .env file to version control
# ============================================================

# --- Database ---
POSTGRES_DB=docai
POSTGRES_USER=docai
POSTGRES_PASSWORD=change_me_strong_password

# --- Spring datasource (used by both services) ---
SPRING_DATABASE_URL=jdbc:postgresql://postgres:5432/docai
SPRING_DATABASE_USERNAME=docai
SPRING_DATABASE_PASSWORD=change_me_strong_password

# --- OpenAI / LLM ---
OPENAI_API_KEY=sk-...
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# --- Security ---
# Generate with: openssl rand -base64 64
JWT_SECRET=replace_with_64_char_base64_encoded_secret
JWT_EXPIRATION_MS=86400000

# --- CORS ---
# Comma-separated list of allowed frontend origins
CORS_ALLOWED_ORIGINS=*

# --- Rate limiting ---
RATE_LIMIT_PER_MINUTE=30

# --- Frontend API URLs (used at Docker build time) ---
VITE_BACKEND_URL=http://localhost:8080
VITE_INGESTOR_URL=http://localhost:8081
