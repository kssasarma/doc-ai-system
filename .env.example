# ============================================================
# doc-ai-system — Production Environment Variables
# cp .env.example .env  then fill in the values below
# NEVER commit the .env file to version control
# ============================================================

# --- Database ---
POSTGRES_DB=docai
POSTGRES_USER=docai
POSTGRES_PASSWORD=change_me_strong_password

# --- Spring datasource (used by both services) ---
SPRING_DATABASE_URL=jdbc:postgresql://postgres:5432/docai
SPRING_DATABASE_USERNAME=docai
SPRING_DATABASE_PASSWORD=change_me_strong_password

# --- OpenAI / LLM ---
OPENAI_API_KEY=sk-...
OPENAI_BASE_URL=https://api.openai.com
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# --- Security ---
# Generate with: openssl rand -base64 64
# Required in the `prod` Spring profile (docker-compose.prod.yml, k8s) — startup fails if unset,
# on purpose, rather than falling back to the committed dev-only default.
JWT_SECRET=replace_with_64_char_base64_encoded_secret
JWT_EXPIRATION_MS=86400000

# First-run SUPER_ADMIN, created once when the users table is empty (must change password on
# first login). Required in the `prod` Spring profile — same fail-fast reasoning as JWT_SECRET.
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_EMAIL=admin@docs-inator.local
SEED_ADMIN_PASSWORD=replace_with_a_strong_random_password

# --- CORS ---
# Comma-separated list of allowed frontend origins. Credentials (cookies/auth headers) are
# allowed on these requests, so browsers and Spring both reject "*" here — list explicit
# origins for every environment that talks to this API.
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# --- Rate limiting ---
RATE_LIMIT_PER_MINUTE=30

# --- Object storage (document-ingestor) ---
# Local/docker-compose.yml: bundled MinIO, these defaults just work.
# docker-compose.prod.yml: point at your own S3-compatible store — set S3_ENDPOINT to your
# MinIO/other endpoint, or leave it blank entirely for real AWS S3 (region-based endpoint
# resolution) and set S3_PATH_STYLE_ACCESS=false.
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change_me_strong_password
S3_BUCKET=docai-documents
S3_ENDPOINT=http://minio:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=change_me_strong_password
S3_PATH_STYLE_ACCESS=true

# --- Frontend API URLs (used at Docker build time) ---
# Leave both empty for a normal deploy: the frontend image's built-in nginx reverse-proxies
# /api/** to the two backend containers on the same origin (see frontend/Dockerfile and
# frontend/templates/default.conf.template), so the bundle should call relative paths, not an
# absolute URL baked in at build time. Only set these for a standalone frontend build that talks
# directly to a backend with no reverse proxy in front of it.
VITE_BACKEND_URL=
VITE_INGESTOR_URL=
